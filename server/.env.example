# Database
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/trackledger"

# App ↔ browser (same origin as users see; used for CORS + OAuth redirects back to UI)
# Development (Vite): http://localhost:5173
# Production: https://trackledger.nl
CLIENT_URL=http://localhost:5173

# Session
SESSION_SECRET=change-me-in-production

# Google OAuth (Calendar connect — not used for login)
# Create an OAuth 2.0 Client ID (Web application) in Google Cloud Console.
# Authorized redirect URIs must match GOOGLE_REDIRECT_URI exactly (multiple URIs allowed in Console).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Examples:
#   Dev via Vite proxy:  http://localhost:5173/api/auth/google/callback
#   Dev direct API port: http://localhost:3001/api/auth/google/callback
#   Production:          https://trackledger.nl/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
