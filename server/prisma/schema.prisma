generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int        @id @default(autoincrement())
  email                String     @unique
  name                 String?
  googleId             String?    @unique
  googleAccessToken    String?    @db.Text
  googleRefreshToken   String?    @db.Text
  selectedCalendarId   String?
  createdAt            DateTime   @default(now())
  events               CalendarEvent[]
  customers            Customer[]
  tasks                Task[]
}

model Customer {
  id                 Int             @id @default(autoincrement())
  name               String
  email              String?
  phone              String?
  selectedCalendarId String?         // gekoppelde Google-agenda
  userId             Int
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs               Job[]
  tracks             Track[]
  calendarEvents     CalendarEvent[]
  createdAt          DateTime        @default(now())
}

model Job {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  startDate  DateTime
  endDate    DateTime
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tracks     Track[]
  createdAt  DateTime @default(now())
}

model Track {
  id         Int         @id @default(autoincrement())
  name       String
  jobId      Int
  job        Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customerId Int
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  trackTasks TrackTask[]
  createdAt  DateTime    @default(now())

  @@unique([customerId, name])
}

enum TrackTaskStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
}

model Task {
  id                   Int         @id @default(autoincrement())
  name                 String
  slug                 String?
  description          String?     @db.Text
  defaultEstimatedHours Decimal?   @db.Decimal(10, 2)
  isActive             Boolean     @default(true)
  userId               Int
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackTasks           TrackTask[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@unique([userId, slug])
}

model TrackTask {
  id              Int             @id @default(autoincrement())
  trackId         Int
  track           Track           @relation(fields: [trackId], references: [id], onDelete: Cascade)
  taskId          Int
  task            Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  titleOverride   String?
  notes           String?         @db.Text
  estimatedHours  Decimal?       @db.Decimal(10, 2)
  actualHours     Decimal        @default(0) @db.Decimal(10, 2)
  status           TrackTaskStatus @default(NOT_STARTED)
  sortOrder        Int             @default(0)
  calendarEvents   CalendarEvent[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([trackId, taskId])
}

model CalendarEvent {
  id                   Int        @id @default(autoincrement())
  googleEventId        String?
  calendarId           String     @default("primary")
  title                String
  description          String?    @db.Text
  start                DateTime
  end                  DateTime
  location             String?
  durationMinutes      Int?       // cached for quick aggregation
  userId               Int
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId           Int?       // gekoppeld aan klant
  customer             Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedTrackTaskId  Int?
  assignedTrackTask    TrackTask? @relation(fields: [assignedTrackTaskId], references: [id], onDelete: SetNull)
  assignmentSource     String     @default("UNASSIGNED") // AUTO, MANUAL, UNASSIGNED
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}
