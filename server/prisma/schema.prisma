generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int        @id @default(autoincrement())
  email                String     @unique
  name                 String?
  passwordHash         String?    @db.Text
  googleId             String?    @unique
  googleAccessToken    String?    @db.Text
  googleRefreshToken   String?    @db.Text
  googleConnectedAt    DateTime?
  selectedCalendarId   String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  events               CalendarEvent[]
  customers            Customer[]
  tasks                Task[]
  jobs                 Job[]
  tracks               Track[]
  trackTasks           TrackTask[]
  trackSharesCreated   TrackShare[]
}

model Customer {
  id                 Int             @id @default(autoincrement())
  name               String
  email              String?
  phone              String?
  selectedCalendarId String?         // gekoppelde Google-agenda
  userId             Int
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs               Job[]
  tracks             Track[]
  calendarEvents     CalendarEvent[]
  createdAt          DateTime        @default(now())
}

model Job {
  id         Int      @id @default(autoincrement())
  name       String
  startDate  DateTime
  endDate    DateTime
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks     Track[]
  createdAt  DateTime @default(now())

  @@unique([customerId, name])
  @@index([userId])
}

model Track {
  id         Int         @id @default(autoincrement())
  name       String
  jobId      Int
  job        Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customerId Int
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId     Int
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackTasks TrackTask[]
  share      TrackShare?
  createdAt  DateTime    @default(now())

  @@unique([customerId, name])
  @@index([userId])
}

/// Read-only share link for customer view of a track (no customer login).
model TrackShare {
  id              Int       @id @default(autoincrement())
  trackId         Int       @unique
  track           Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  token           String    @unique @db.VarChar(64)
  isActive        Boolean   @default(true)
  expiresAt       DateTime?
  createdByUserId Int
  createdBy       User      @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([token])
}

enum TrackTaskStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
}

model Task {
  id                   Int         @id @default(autoincrement())
  name                 String
  slug                 String?
  description          String?     @db.Text
  defaultEstimatedHours Decimal?   @db.Decimal(10, 2)
  isActive             Boolean     @default(true)
  userId               Int
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackTasks           TrackTask[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@unique([userId, slug])
}

model TrackTask {
  id                   Int             @id @default(autoincrement())
  trackId              Int
  track                Track           @relation(fields: [trackId], references: [id], onDelete: Cascade)
  taskId               Int
  task                 Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId               Int
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  titleOverride        String?
  notes                String?         @db.Text
  estimatedHours       Decimal?        @db.Decimal(10, 2)
  actualHours          Decimal         @default(0) @db.Decimal(10, 2)
  status               TrackTaskStatus @default(NOT_STARTED)
  sortOrder            Int             @default(0)
  deadlineAt           DateTime?
  deadlineGoogleEventId String?
  deadlineSyncStatus   String?         // PENDING, SYNCED, ERROR, DELETED
  deadlineLastSyncedAt DateTime?
  deadlineSyncError    String?         @db.Text
  calendarEvents      CalendarEvent[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([trackId, taskId])
  @@index([userId])
}

model CalendarEvent {
  id                   Int        @id @default(autoincrement())
  googleEventId        String?
  calendarId           String     @default("primary")
  title                String
  description          String?    @db.Text
  start                DateTime
  end                  DateTime
  location             String?
  durationMinutes      Int?       // cached for quick aggregation
  userId               Int
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId           Int?       // gekoppeld aan klant
  customer             Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedTrackTaskId  Int?
  assignedTrackTask    TrackTask? @relation(fields: [assignedTrackTaskId], references: [id], onDelete: SetNull)
  assignmentSource     String     @default("UNASSIGNED") // AUTO, MANUAL, UNASSIGNED
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}
